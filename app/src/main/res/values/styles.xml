<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="fontLabel" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/textColorPrimary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="fontInfo" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/textColorSecondary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextTitle" parent="Widget.MaterialComponents.TextView">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textColorPrimary</item>
    </style>

    <style name="TextSubtitle" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/colorTextSubtitle</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="button_style" parent="Widget.MaterialComponents.Button.OutlinedButton.Icon">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/textColorPrimary</item>
        <item name="backgroundTint">@android:color/white</item>
        <item name="strokeColor">?attr/colorSecondary</item>
        <item name="iconTint">?attr/colorSecondary</item>
    </style>

</resources>